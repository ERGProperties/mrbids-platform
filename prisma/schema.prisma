generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum AuctionStatus {
  DRAFT
  LIVE
  CLOSED
}

enum MarketplaceAuctionStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
}

enum ServiceFeeStatus {
  PENDING
  PAID
  FAILED
}

model Auction {
  id            String   @id @default(cuid())

  slug          String?  @unique
  title         String?
  addressLine   String?
  cityStateZip  String?

  imagesPath    String?
  images        Json?
  coverImage    String?

  propertyType  String?
  beds          Int?
  baths         Float?
  sqft          Int?
  yearBuilt     Int?
  condition     String?
  description   String?

  startingBid   Int?
  bidIncrement  Int?
  reserveAmount Int?
  arv           Int?
  finalPrice    Int?

  startAt       DateTime?
  endAt         DateTime?

  status        AuctionStatus @default(DRAFT)
  result        String?

  // WINNER
  winnerId      String?
  winner        User? @relation("AuctionWinner", fields: [winnerId], references: [id])

  bidCount      Int @default(0)
  durationDays  Int?

  bids          Bid[]
  questions     Question[]
  messages      Message[]

  sellerId      String?
  seller        User? @relation("SellerAuctions", fields: [sellerId], references: [id])

  serviceFeeAmount Int?
  serviceFeeStatus ServiceFeeStatus?
  serviceFeePaidAt DateTime?

  endingSoonSent  Boolean @default(false)
  endedEmailsSent Boolean @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([sellerId])
}

model MarketplaceAuction {
  id            String   @id @default(cuid())

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  title         String
  description   String?

  category      String

  images        Json?
  coverImage    String?

  startingBid   Int
  bidIncrement  Int @default(1)

  currentBid    Int @default(0)
  bidCount      Int @default(0)

  startAt       DateTime?
  endAt         DateTime?

  status        MarketplaceAuctionStatus @default(DRAFT)

  sellerId      String
  seller        User @relation(fields: [sellerId], references: [id])

  // WINNER
  winnerId      String?
  winner        User? @relation("MarketplaceAuctionWinner", fields: [winnerId], references: [id])

  bids          MarketplaceBid[]

  endingSoonSent Boolean @default(false)

  @@index([sellerId])
  @@index([status])
}

model MarketplaceBid {
  id          String   @id @default(cuid())

  amount      Int

  createdAt   DateTime @default(now())

  auctionId   String
  auction     MarketplaceAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  bidderId    String
  bidder      User @relation(fields: [bidderId], references: [id])

  @@index([auctionId, createdAt])
  @@index([bidderId])
}

model Bid {
  id        String   @id @default(cuid())

  amount    Int
  createdAt DateTime @default(now())

  auctionId String
  auction   Auction  @relation(fields: [auctionId], references: [id])

  bidderId  String
  bidder    User     @relation(fields: [bidderId], references: [id])

  @@index([auctionId, createdAt])
}

model Question {
  id         String   @id @default(cuid())

  question   String
  answer     String?

  createdAt  DateTime @default(now())
  answeredAt DateTime?

  auctionId  String
  auction    Auction  @relation(fields: [auctionId], references: [id])

  userId     String
  user       User     @relation(fields: [userId], references: [id])

  @@index([auctionId])
}

model Message {
  id         String   @id @default(cuid())

  auctionId  String
  auction    Auction  @relation(fields: [auctionId], references: [id])

  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  receiverId String
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])

  body       String

  createdAt  DateTime @default(now())

  @@index([auctionId])
  @@index([senderId])
  @@index([receiverId])
}

model NotificationLog {
  id          String   @id @default(cuid())

  userId      String

  type        String

  auctionId   String?

  createdAt   DateTime @default(now())

  metadata    Json?

  user        User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([type])
  @@index([auctionId])
}

model User {
  id        String   @id @default(cuid())

  name          String?
  email         String? @unique
  emailVerified DateTime?
  image         String?

  role      Role @default(USER)

  bio                 String?
  avatarUrl           String?

  isMarketplaceSeller Boolean @default(false)

  sellerCategory      String?
  tiktokUsername      String?
  sellerBio           String?

  createdAt DateTime @default(now())

  isVerifiedBidder Boolean @default(false)

  bids      Bid[]

  auctions  Auction[] @relation("SellerAuctions")

  marketplaceAuctions MarketplaceAuction[]

  marketplaceBids MarketplaceBid[]

  wonAuctions Auction[] @relation("AuctionWinner")

  wonMarketplaceAuctions MarketplaceAuction[] @relation("MarketplaceAuctionWinner")

  questions Question[]

  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  pushSubscriptions PushSubscription[]

  notificationLogs NotificationLog[]

  accounts  Account[]
  sessions  Session[]
}

model PushSubscription {
  id        String   @id @default(cuid())

  userId    String
  user      User     @relation(fields: [userId], references: [id])

  endpoint  String   @unique
  p256dh    String
  auth      String

  createdAt DateTime @default(now())
}

model Account {
  id                String  @id @default(cuid())

  userId            String

  type              String
  provider          String
  providerAccountId String

  refresh_token String?
  access_token  String?
  expires_at    Int?
  token_type    String?
  scope         String?
  id_token      String?
  session_state String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())

  sessionToken String   @unique

  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}