generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Auction {
  id               String            @id @default(cuid())
  slug             String?           @unique
  title            String?
  addressLine      String?
  cityStateZip     String?
  imagesPath       String?
  images           Json?
  coverImage       String?
  propertyType     String?
  beds             Int?
  baths            Float?
  sqft             Int?
  condition        String?
  description      String?
  startingBid      Int?
  bidIncrement     Int?
  reserveAmount    Int?
  arv              Int?
  finalPrice       Int?
  startAt          DateTime?
  endAt            DateTime?
  status           AuctionStatus     @default(DRAFT)
  result           String?
  bidCount         Int               @default(0)
  durationDays     Int?
  sellerId         String?
  serviceFeeAmount Int?
  serviceFeeStatus ServiceFeeStatus?
  serviceFeePaidAt DateTime?
  endingSoonSent   Boolean           @default(false)
  endedEmailsSent  Boolean           @default(false)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  yearBuilt        Int?
  winnerId         String?
  seller           User?             @relation("SellerAuctions", fields: [sellerId], references: [id])
  winner           User?             @relation("AuctionWinner", fields: [winnerId], references: [id])
  bids             Bid[]
  messages         Message[]
  questions        Question[]

  @@index([sellerId])
}

model MarketplaceAuction {
  id                       String                   @id @default(cuid())
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  title                    String
  description              String?
  category                 String
  images                   Json?
  coverImage               String?
  startingBid              Int
  bidIncrement             Int                      @default(1)
  currentBid               Int                      @default(0)
  startAt                  DateTime?
  endAt                    DateTime?
  status                   MarketplaceAuctionStatus @default(DRAFT)
  sellerId                 String
  bidCount                 Int                      @default(0)
  winnerId                 String?
  durationMinutes          Int                      @default(5)
  retailPrice              Int?
  paidAt                   DateTime?
  paymentStatus            String?                  @default("UNPAID")
  stripeSessionId          String?
  completedAt              DateTime?
  deliveredAt              DateTime?
  fulfillmentNotes         String?
  fulfillmentStatus        String?                  @default("PENDING")
  shippedAt                DateTime?
  trackingNumber           String?
  shippingCost             Int?                     @default(0)
  shippingPaid             Boolean                  @default(false)
  marketplaceFeeAmount     Int?
  payoutSentAt             DateTime?
  sellerPayoutAmount       Int?
  stripePaymentIntentId    String?
  freeShipping             Boolean                  @default(false)
  localPickup              Boolean                  @default(false)
  shippingLabel            String?
  shippingPreset           String?
  shippingType             String?                  @default("preset")
  reservePrice             Int?
  fifteenMinEndingSoonSent Boolean                  @default(false)
  fiveMinEndingSoonSent    Boolean                  @default(false)
  oneHourEndingSoonSent    Boolean                  @default(false)
  seller                   User                     @relation(fields: [sellerId], references: [id])
  winner                   User?                    @relation("MarketplaceAuctionWinner", fields: [winnerId], references: [id])
  bids                     MarketplaceBid[]
  watchlistedBy            Watchlist[]

  @@index([sellerId])
  @@index([status])
  @@index([paymentStatus])
  @@index([fulfillmentStatus])
}

model MarketplaceBid {
  id        String             @id @default(cuid())
  amount    Int
  createdAt DateTime           @default(now())
  auctionId String
  bidderId  String
  auction   MarketplaceAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  bidder    User               @relation(fields: [bidderId], references: [id])

  @@index([auctionId, createdAt])
  @@index([bidderId])
}

model Watchlist {
  id        String             @id @default(cuid())
  createdAt DateTime           @default(now())
  userId    String
  auctionId String
  auction   MarketplaceAuction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user      User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@index([userId])
  @@index([auctionId])
}

model Bid {
  id        String   @id @default(cuid())
  amount    Int
  createdAt DateTime @default(now())
  auctionId String
  bidderId  String
  auction   Auction  @relation(fields: [auctionId], references: [id])
  bidder    User     @relation(fields: [bidderId], references: [id])

  @@index([auctionId, createdAt])
}

model Question {
  id         String    @id @default(cuid())
  question   String
  answer     String?
  createdAt  DateTime  @default(now())
  answeredAt DateTime?
  auctionId  String
  userId     String
  auction    Auction   @relation(fields: [auctionId], references: [id])
  user       User      @relation(fields: [userId], references: [id])

  @@index([auctionId])
}

model Message {
  id         String   @id @default(cuid())
  auctionId  String
  senderId   String
  receiverId String
  body       String
  createdAt  DateTime @default(now())
  auction    Auction  @relation(fields: [auctionId], references: [id])
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])

  @@index([auctionId])
  @@index([senderId])
  @@index([receiverId])
}

model NotificationLog {
  id        String    @id @default(cuid())
  userId    String
  type      String
  auctionId String?
  createdAt DateTime  @default(now())
  metadata  Json?
  isRead    Boolean   @default(false)
  link      String?
  message   String?   @default("")
  readAt    DateTime?
  title     String?   @default("")
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([auctionId])
}

model User {
  id                       String               @id @default(cuid())
  name                     String?
  email                    String?              @unique
  emailVerified            DateTime?
  image                    String?
  role                     Role                 @default(USER)
  createdAt                DateTime             @default(now())
  isVerifiedBidder         Boolean              @default(false)
  avatarUrl                String?
  bio                      String?
  isMarketplaceSeller      Boolean              @default(false)
  sellerBio                String?
  sellerCategory           String?
  tiktokUsername           String?
  stripeAccountId          String?
  stripeOnboardingComplete Boolean              @default(false)

  username                 String?              @unique

  onboardingCompleted      Boolean              @default(false)
  onboardingStep           Int                  @default(1)

accounts                 Account[]
  auctions                 Auction[]            @relation("SellerAuctions")
  wonAuctions              Auction[]            @relation("AuctionWinner")
  bids                     Bid[]
  marketplaceAuctions      MarketplaceAuction[]
  wonMarketplaceAuctions   MarketplaceAuction[] @relation("MarketplaceAuctionWinner")
  marketplaceBids          MarketplaceBid[]
  receivedMessages         Message[]            @relation("ReceivedMessages")
  sentMessages             Message[]            @relation("SentMessages")
  notificationLogs         NotificationLog[]
  pushSubscriptions        PushSubscription[]
  questions                Question[]
  sessions                 Session[]
  watchlist                Watchlist[]
}

enum PushPlatform {
  WEB
  FCM
}

model PushSubscription {
  id         String       @id @default(cuid())
  userId     String
  endpoint   String       @unique
  platform   PushPlatform @default(WEB)
  p256dh     String?
  auth       String?
  createdAt  DateTime     @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  USER
  ADMIN
}

enum AuctionStatus {
  DRAFT
  LIVE
  CLOSED
}

enum MarketplaceAuctionStatus {
  DRAFT
  LIVE
  ENDED
  SCHEDULED
  RESERVE_NOT_MET
}

enum ServiceFeeStatus {
  PENDING
  PAID
  FAILED
}

enum NotificationType {
  OUTBID
  ENDING_SOON
  AUCTION_WON
  AUCTION_LOST
  WATCHLIST_ENDING
  NEW_BID
  SYSTEM
}
